# Canva design URL (the shareable view or edit link)
CANVA_URL=https://www.canva.com/design/XXXXX/view

# Canva API credentials (create at https://www.canva.dev)
# Set redirect URL to: http://127.0.0.1:8420/oauth/callback
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# Delay in seconds between posting each status (avoid rate limiting)
DELAY_BETWEEN_STATUSES=5

# Run browser in headless mode (set to false for debugging or first-time setup)
HEADLESS=true
